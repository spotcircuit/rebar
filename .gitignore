# =============================================================================
# REBAR PRIVATE — PERSONAL WORKING SET
# =============================================================================
# This gitignore is for the PRIVATE repo (spotcircuit/rebar).
# The PUBLIC repo (spotcircuit/rebar-public) has its own strict whitelist.
# Keep client data, private apps, and working docs locally but never push to public.
# =============================================================================

# Credentials — never commit even to private
clients/*/.env
apps/**/.env
system/.env
**/.env.local
*.env
!.env.example
!.env.template
!*.env.example
!*.env.template
*.key
*.pem
secrets/
credentials/

# Paperclip runtime state (auto-generated IDs tied to local instance)
system/.paperclip-ids.json
system/.venv/

# Build artifacts
node_modules/
package-lock.json
bun.lock
dist/
.prisma/
__pycache__/
*.pyc

# OS + Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Workspace/backup branches
.paperclip/instances/default/workspaces/
