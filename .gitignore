# Credentials -- never commit
clients/*/client.yaml
!clients/_templates/client.yaml
clients/*/.env
apps/*/app.yaml
!apps/_templates/app.yaml
system/.env
system/.paperclip-ids.json
system/.venv/

# Per-client/app working docs
clients/*/comments.md
clients/*/research/
apps/*/research/
apps/**/backend/.env
apps/**/.env

# Node
node_modules/
package-lock.json
bun.lock

# App build artifacts
dist/
.prisma/

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Apps -- same pattern as clients
apps/*/app.yaml
!apps/_templates/app.yaml

# Private apps -- not part of public release
apps/social-scout/
apps/prepitch/
apps/getrankedlocal/
apps/care-agent-evaluator/

# Private clients -- never committed
clients/restorefast/
clients/power-platform-dashboard/
clients/experity/
clients/aviation-dispatch/

# Private wiki — never committed
wiki-private/

# Chrome extensions -- proprietary scraping/engagement tooling
extensions/

# Tools -- tool.yaml is NOT gitignored (no secrets, just config)
# But tool-specific research dirs are
tools/*/research/

# Paperclip runtime state
system/.paperclip-ids.json

# GTM sensitive data
system/gtm/prospects.yaml
system/gtm/metrics-log.jsonl

# Drafts and research (working docs, not source of truth)
system/drafts/
docs/research/

# Scout CSV reports
raw/*.csv

# Raw processed files may contain secrets/session data
raw/processed/
raw/next-session.md
raw/eval-*.md
