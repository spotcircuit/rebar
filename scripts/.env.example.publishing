# Copy to .env and fill in real values.

# --- spotcircuit-site (publish-site.sh) ---
# Absolute path to a local checkout of the spotcircuit-site repo.
# Vercel watches the repo and auto-deploys on push.
SPOTCIRCUIT_SITE_REPO=
# Directory inside the site repo where posts live. Default: blog
SPOTCIRCUIT_SITE_BLOG_DIR=blog
# Branch to push to. Default: main
SPOTCIRCUIT_SITE_BRANCH=main
# Remote to push to. Default: origin
SPOTCIRCUIT_SITE_REMOTE=origin
# Public base URL served by Vercel. Default: https://spotcircuit.com
SPOTCIRCUIT_PUBLIC_URL=https://spotcircuit.com
# Set to "1" to commit without pushing (local dry-runs).
SPOTCIRCUIT_SITE_NO_PUSH=

# --- Chrome CDP (all platform publishers: Medium/Substack/LinkedIn/Facebook) ---
# URL of the user's debug Chrome (C:\temp\chrome-debug.bat).
# All platform publishers connect here and drive the already-logged-in
# session — no API keys or OAuth tokens required.
CHROME_CDP_URL=http://172.20.240.1:9222
# Timeout (ms) for editor-load / autosave waits.
CDP_HEADLESS_TIMEOUT=45000
# Set to "1" to skip CDP entirely and run the pipeline in dry-run mode.
CROSS_POST_DRY_RUN=

# --- Substack (publish-substack-cdp.py) ---
# Publication subdomain, e.g. "mycrew" for https://mycrew.substack.com
SUBSTACK_PUBLICATION=

# --- Facebook (publish-facebook-cdp.py) ---
# Full URL of the business page whose composer the script should drive.
FACEBOOK_PAGE_URL=

# --- Cross-post orchestrator ---
# Humanizer gate: reject posts whose AI-likeness score exceeds this.
HUMANIZER_THRESHOLD=0.3
# Override canonical URL passed to Medium / Substack / LinkedIn Article.
# Defaults to the site URL (https://spotcircuit.com/blog/<slug>).
CANONICAL_BASE_URL=
# Paperclip agent id for the blog_post_ready hook (defaults to PAPERCLIP_AGENT_ID).
BLOG_WRITER_AGENT_ID=
